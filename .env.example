# JobPilot Environment Variables
# Copy this to .env and fill in your values

# PostgreSQL Database
DATABASE_URL=postgresql://jobpilot:jobpilot@localhost/jobpilot

# SerpAPI (for LinkedIn/Indeed job searches)
# Get free API key: https://serpapi.com
SERPAPI_API_KEY=your_serpapi_key_here

# Qdrant Vector Database (W1)
# Default: localhost with in-memory storage
QDRANT_HOST=127.0.0.1:6333
QDRANT_API_KEY=

# OpenAI API (optional, for cover letter quality)
# Only needed if you want hosted LLM support
OPENAI_API_KEY=your_openai_key_here

# Local LLM (optional, W1)
# Set to use Ollama for local inference
JOBPILOT_LLM_PROVIDER=local
JOBPILOT_LLM_MODEL=llama3.1:8b
OLLAMA_URL=http://localhost:11434
