# JobPilot Environment Variables
# Copy this to .env and fill in your values

# Database
# Default: local SQLite (zero setup). For Postgres, use docker-compose.yml:
#   DATABASE_URL=postgresql://jobpilot:jobpilot_dev@localhost/jobpilot_db
DATABASE_URL=sqlite:///jobpilot_local.db

# OpenAI API (optional — pipeline gracefully falls back to local
# sentence-transformers scoring + Ollama if absent or quota-exceeded)
OPENAI_API_KEY=

# Local LLM via Ollama (optional)
JOBPILOT_LLM_PROVIDER=local
JOBPILOT_LLM_MODEL=llama3.1:8b
OLLAMA_URL=http://localhost:11434

# Qdrant vector DB (used by RAG ingest — optional for the morning pipeline)
QDRANT_HOST=127.0.0.1:6333
QDRANT_API_KEY=

# SerpAPI (optional legacy — current company scraper uses Playwright + ATS APIs)
SERPAPI_API_KEY=

# Candidate profile — used in cover letters and PDF headers
CANDIDATE_NAME=Your Full Name
CANDIDATE_EMAIL=your.email@example.com
CANDIDATE_PHONE=+1 (555) 000-0000
CANDIDATE_LINKEDIN=linkedin.com/in/yourprofile
CANDIDATE_PORTFOLIO=github.com/yourname

# Resume — PDF auto-extracted; .txt is read directly
RESUME_PATH=data/master_resume.pdf

# Tailoring threshold (0-100). LLM scoring sits 60-95;
# local cosine fallback sits 15-45 — keep 40 for either path.
JOBPILOT_MIN_MATCH_SCORE=40

# Email digest (optional, for `run_pipeline --email`)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=
